# ============================================================
# Radar Financeiro — variáveis de ambiente
# Copie para .env.local e preencha. As marcadas com * são obrigatórias.
# No Vercel: Settings → Environment Variables
# ============================================================

# --- Banco de dados (NeonDB / PostgreSQL) * ---
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"

# --- JWT * ---
JWT_SECRET="troque_por_string_aleatoria_longa"

# --- Anthropic (Claude IA) * ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Resend (emails transacionais) * ---
RESEND_API_KEY="re_..."
EMAIL_FROM="Radar Financeiro <noreply@seudominio.com>"

# --- Cron jobs (Vercel Cron) * ---
# Gere com: openssl rand -hex 32
# Configure também em Vercel → Settings → Cron Secret ou como env var
CRON_SECRET="troque_por_segredo_aleatorio"

# --- Segurança: Webhook Z-API ---
# Se preenchido, o webhook só aceita requisições com ?secret=ESSE_VALOR na URL.
# Gere com: openssl rand -hex 24
# Depois atualize a URL do webhook no painel Z-API para incluir ?secret=ESSE_VALOR
ZAPI_WEBHOOK_SECRET=""

# --- Asaas (cobrança de inadimplentes) ---
# true = sandbox (testes); remova ou coloque false em produção
ASAAS_SANDBOX="true"
# Chave global de fallback (cada empresa configura a própria em /empresa/configuracoes)
ASAAS_API_KEY=""
# Token de autenticação do webhook Asaas (configurar em Asaas → Configurações → Webhooks)
ASAAS_WEBHOOK_TOKEN=""

# --- Z-API (WhatsApp) ---
# Instância global de fallback para alertas
# Cada empresa pode configurar a própria em /empresa/configuracoes
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""
ZAPI_CLIENT_TOKEN=""

# --- App URL ---
NEXT_PUBLIC_APP_URL="https://seudominio.com"
