generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEGADO — modelos originais preservados (não mexer)
// ─────────────────────────────────────────────────────────────────────────────

model Bpo {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senhaHash    String
  telefone     String?
  plano        String   @default("basico")
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  clientes Cliente[]
  usuarios UsuarioBpo[]
}

model UsuarioBpo {
  id        String   @id @default(uuid())
  bpoId     String
  bpo       Bpo      @relation(fields: [bpoId], references: [id])
  nome      String
  email     String   @unique
  senhaHash String
  role      String   @default("operador")
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
}

model Cliente {
  id           String   @id @default(uuid())
  bpoId        String
  bpo          Bpo      @relation(fields: [bpoId], references: [id])
  nomeEmpresa  String
  cnpj         String?
  setor        String?
  responsavel  String?
  telefone     String?
  email        String?  @unique
  senhaHash    String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  alertaWpp   Boolean  @default(false)
  telefoneWpp String?
  metaLucro   Decimal? @db.Decimal(12, 2)
  metaReceita Decimal? @db.Decimal(12, 2)

  importacoes        Importacao[]
  fechamentos        Fechamento[]
  alertas            Alerta[]
  conversasIA        ConversaIA[]
  contasPagar        ContaPagar[]
  lancamentosManuais LancamentoManual[]
}

model Importacao {
  id                String   @id @default(uuid())
  clienteId         String
  cliente           Cliente  @relation(fields: [clienteId], references: [id])
  tipo              String
  nomeArquivo       String
  mes               Int
  ano               Int
  status            String   @default("processando")
  erro              String?
  totalLinhas       Int?
  linhasProcessadas Int?
  criadoEm          DateTime @default(now())

  lancamentos Lancamento[]
}

model Lancamento {
  id           String     @id @default(uuid())
  importacaoId String
  importacao   Importacao @relation(fields: [importacaoId], references: [id])
  clienteId    String
  mes          Int
  ano          Int

  favorecido      String?
  planoConta      String
  grupoConta      String
  area            String?
  advogado        String?
  descricao       String?
  dataCompetencia DateTime?
  valor           Decimal   @db.Decimal(12, 2)
  dataVencimento  DateTime?
  statusPg        String?
  dataPagamento   DateTime?
  formaPagamento  String?
  banco           String?
  conciliado      Boolean   @default(false)
  observacoes     String?

  tipo     String
  subtipo  String?
  previsto Boolean @default(false)
}

model Fechamento {
  id           String   @id @default(uuid())
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  mes          Int
  ano          Int
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  receitaBruta          Decimal @db.Decimal(12, 2) @default(0)
  honHonorariosIniciais Decimal @db.Decimal(12, 2) @default(0)
  honHonorariosMensais  Decimal @db.Decimal(12, 2) @default(0)
  honConsultas          Decimal @db.Decimal(12, 2) @default(0)
  honExito              Decimal @db.Decimal(12, 2) @default(0)
  honMultaCancelamento  Decimal @db.Decimal(12, 2) @default(0)
  repasseExito          Decimal @db.Decimal(12, 2) @default(0)
  impostos              Decimal @db.Decimal(12, 2) @default(0)
  receitaLiquida        Decimal @db.Decimal(12, 2) @default(0)

  custosDiretos      Decimal @db.Decimal(12, 2) @default(0)
  margemContribuicao Decimal @db.Decimal(12, 2) @default(0)
  percMargem         Decimal @db.Decimal(6, 2)  @default(0)

  despesasPessoal   Decimal @db.Decimal(12, 2) @default(0)
  despesasMarketing Decimal @db.Decimal(12, 2) @default(0)
  despesasGerais    Decimal @db.Decimal(12, 2) @default(0)
  totalDespesasAdm  Decimal @db.Decimal(12, 2) @default(0)

  lucroOperacional Decimal @db.Decimal(12, 2) @default(0)
  percLucroOp      Decimal @db.Decimal(6, 2)  @default(0)

  retiradaSocios      Decimal @db.Decimal(12, 2) @default(0)
  resultadoFinanceiro Decimal @db.Decimal(12, 2) @default(0)
  receitaJuros        Decimal @db.Decimal(12, 2) @default(0)
  despesaJuros        Decimal @db.Decimal(12, 2) @default(0)

  lucroLiquido Decimal @db.Decimal(12, 2) @default(0)
  percLucroLiq Decimal @db.Decimal(6, 2)  @default(0)

  distribuicaoLucros   Decimal @db.Decimal(12, 2) @default(0)
  investimentos        Decimal @db.Decimal(12, 2) @default(0)
  emprestimosEntrada   Decimal @db.Decimal(12, 2) @default(0)
  emprestimosPagamento Decimal @db.Decimal(12, 2) @default(0)
  parcelamentoImpostos Decimal @db.Decimal(12, 2) @default(0)
  resgateAplicacao     Decimal @db.Decimal(12, 2) @default(0)
  aplicacaoFinanceira  Decimal @db.Decimal(12, 2) @default(0)
  aporteSocios         Decimal @db.Decimal(12, 2) @default(0)

  resultadoCaixa Decimal? @db.Decimal(12, 2)
  saldoAnterior  Decimal? @db.Decimal(12, 2)
  saldoFinal     Decimal? @db.Decimal(12, 2)

  resultadosPorSetor Json?

  receitaPrevista Decimal? @db.Decimal(12, 2)
  despesaPrevista Decimal? @db.Decimal(12, 2)

  pdfUrl      String?
  pdfGeradoEm DateTime?

  @@unique([clienteId, mes, ano])
}

model Alerta {
  id        String    @id @default(uuid())
  clienteId String
  cliente   Cliente   @relation(fields: [clienteId], references: [id])
  tipo      String
  titulo    String
  mensagem  String
  canal     String    @default("whatsapp")
  enviado   Boolean   @default(false)
  enviadoEm DateTime?
  erro      String?
  criadoEm  DateTime  @default(now())
}

model ConversaIA {
  id          String   @id @default(uuid())
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  pergunta    String
  resposta    String
  contextoMes Int?
  contextoAno Int?
  criadoEm    DateTime @default(now())
}

model ContaPagar {
  id           String    @id @default(uuid())
  clienteId    String
  cliente      Cliente   @relation(fields: [clienteId], references: [id])
  descricao    String
  fornecedor   String?
  valor        Decimal   @db.Decimal(12, 2)
  vencimento   DateTime
  recorrente   Boolean   @default(false)
  frequencia   String?
  status       String    @default("pendente")
  pagoEm       DateTime?
  categoria    String?
  observacoes  String?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
}

model LancamentoManual {
  id           String   @id @default(uuid())
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  tipo         String
  descricao    String
  favorecido   String?
  planoConta   String
  grupoConta   String
  tipoContabil String
  valor        Decimal  @db.Decimal(12, 2)
  data         DateTime
  mes          Int
  ano          Int
  previsto     Boolean  @default(false)
  observacoes  String?
  criadoEm     DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// V2 — novos modelos Radar Financeiro
// ─────────────────────────────────────────────────────────────────────────────

model Usuario {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senhaHash    String
  plano        String   @default("basico") // 'basico' | 'pro' | 'premium'
  ativo        Boolean  @default(true)
  isAdmin      Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Controle de acesso
  papel        String   @default("dono")  // 'dono' | 'funcionario'
  donoId       String?  // para funcionários: ID do Usuario dono da empresa

  asaasCustomerId  String?   // ID do cliente no Asaas da plataforma
  planoValidoAte   DateTime? // data de validade da assinatura paga
  assinatura       AssinaturaRadar?

  contaEmpresa ContaEmpresa?
  contaPessoal ContaPessoal?
}

// ─── MODO EMPRESA ─────────────────────────────────────────────────────────────

model ContaEmpresa {
  id        String  @id @default(uuid())
  usuarioId String  @unique
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  // Dados da empresa
  nomeEmpresa String
  cnpj        String?
  setor       String?

  // Alertas WhatsApp
  telefoneAlerta String? // número para alertas de vencimento
  alertaAtivo    Boolean @default(false)

  // Asaas (cobrança de inadimplentes)
  asaasAtivo   Boolean @default(false)
  asaasApiKey  String? // chave da conta Asaas do usuário
  asaasWebhook String? // URL do webhook configurado no Asaas

  // Z-API (WhatsApp)
  zapiInstanceId  String?
  zapiToken       String?
  zapiClientToken String?

  // Configurações régua de cobrança
  cobrancaDescontoMax  Decimal? @db.Decimal(5, 2) // % máximo de desconto para acordo
  cobrancaParcelasMax  Int?     // parcelas máximas para acordo

  // Metas
  metaLucro   Decimal? @db.Decimal(12, 2)
  metaReceita Decimal? @db.Decimal(12, 2)

  // Token para formulário público de espécie (sem login)
  tokenEspecie String? @default(uuid())

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  importacoes   ImportacaoEmpresa[]
  lancamentos   LancamentoEmpresa[]
  fechamentos   FechamentoEmpresa[]
  contasPagar   ContaPagarEmpresa[]
  alertas       AlertaEmpresa[]
  conversasIA   ConversaIAEmpresa[]
  clientesDevedor ClienteDevedor[]
  conciliacoesDiarias ConciliacaoDiaria[]
}

model ImportacaoEmpresa {
  id                String       @id @default(uuid())
  contaEmpresaId    String
  contaEmpresa      ContaEmpresa @relation(fields: [contaEmpresaId], references: [id])
  tipo              String       // 'receitas' | 'despesas' | 'dre'
  nomeArquivo       String
  mes               Int
  ano               Int
  status            String       @default("processando")
  erro              String?
  totalLinhas       Int?
  linhasProcessadas Int?
  criadoEm          DateTime     @default(now())

  lancamentos LancamentoEmpresa[]
}

model LancamentoEmpresa {
  id             String            @id @default(uuid())
  contaEmpresaId String
  contaEmpresa   ContaEmpresa      @relation(fields: [contaEmpresaId], references: [id])
  importacaoId   String?
  importacao     ImportacaoEmpresa? @relation(fields: [importacaoId], references: [id])
  origem         String            @default("importacao") // 'importacao' | 'manual'
  mes            Int
  ano            Int

  favorecido      String?
  planoConta      String
  grupoConta      String
  area            String?
  advogado        String?
  descricao       String?
  dataCompetencia DateTime?
  valor           Decimal   @db.Decimal(12, 2)
  dataVencimento  DateTime?
  statusPg        String?
  dataPagamento   DateTime?
  formaPagamento  String?
  banco           String?
  conciliado      Boolean   @default(false)
  observacoes     String?

  tipo     String
  subtipo  String?
  previsto Boolean @default(false)

  criadoEm DateTime @default(now())
}

model FechamentoEmpresa {
  id             String       @id @default(uuid())
  contaEmpresaId String
  contaEmpresa   ContaEmpresa @relation(fields: [contaEmpresaId], references: [id])
  mes            Int
  ano            Int
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt

  receitaBruta          Decimal @db.Decimal(12, 2) @default(0)
  honHonorariosIniciais Decimal @db.Decimal(12, 2) @default(0)
  honHonorariosMensais  Decimal @db.Decimal(12, 2) @default(0)
  honConsultas          Decimal @db.Decimal(12, 2) @default(0)
  honExito              Decimal @db.Decimal(12, 2) @default(0)
  honMultaCancelamento  Decimal @db.Decimal(12, 2) @default(0)
  repasseExito          Decimal @db.Decimal(12, 2) @default(0)
  impostos              Decimal @db.Decimal(12, 2) @default(0)
  receitaLiquida        Decimal @db.Decimal(12, 2) @default(0)

  custosDiretos      Decimal @db.Decimal(12, 2) @default(0)
  margemContribuicao Decimal @db.Decimal(12, 2) @default(0)
  percMargem         Decimal @db.Decimal(6, 2)  @default(0)

  despesasPessoal   Decimal @db.Decimal(12, 2) @default(0)
  despesasMarketing Decimal @db.Decimal(12, 2) @default(0)
  despesasGerais    Decimal @db.Decimal(12, 2) @default(0)
  totalDespesasAdm  Decimal @db.Decimal(12, 2) @default(0)

  lucroOperacional Decimal @db.Decimal(12, 2) @default(0)
  percLucroOp      Decimal @db.Decimal(6, 2)  @default(0)

  retiradaSocios      Decimal @db.Decimal(12, 2) @default(0)
  resultadoFinanceiro Decimal @db.Decimal(12, 2) @default(0)
  receitaJuros        Decimal @db.Decimal(12, 2) @default(0)
  despesaJuros        Decimal @db.Decimal(12, 2) @default(0)

  lucroLiquido Decimal @db.Decimal(12, 2) @default(0)
  percLucroLiq Decimal @db.Decimal(6, 2)  @default(0)

  distribuicaoLucros   Decimal @db.Decimal(12, 2) @default(0)
  investimentos        Decimal @db.Decimal(12, 2) @default(0)
  emprestimosEntrada   Decimal @db.Decimal(12, 2) @default(0)
  emprestimosPagamento Decimal @db.Decimal(12, 2) @default(0)
  parcelamentoImpostos Decimal @db.Decimal(12, 2) @default(0)
  resgateAplicacao     Decimal @db.Decimal(12, 2) @default(0)
  aplicacaoFinanceira  Decimal @db.Decimal(12, 2) @default(0)
  aporteSocios         Decimal @db.Decimal(12, 2) @default(0)

  resultadoCaixa Decimal? @db.Decimal(12, 2)
  saldoAnterior  Decimal? @db.Decimal(12, 2)
  saldoFinal     Decimal? @db.Decimal(12, 2)

  resultadosPorSetor    Json?
  resultadosPorAdvogado Json?

  receitaPrevista  Decimal? @db.Decimal(12, 2)
  despesaPrevista  Decimal? @db.Decimal(12, 2)

  // Inadimplência
  totalInadimplente Decimal? @db.Decimal(12, 2)
  totalRecuperado   Decimal? @db.Decimal(12, 2)

  pdfUrl      String?
  pdfGeradoEm DateTime?

  @@unique([contaEmpresaId, mes, ano])
}

model ContaPagarEmpresa {
  id             String       @id @default(uuid())
  contaEmpresaId String
  contaEmpresa   ContaEmpresa @relation(fields: [contaEmpresaId], references: [id])
  descricao      String
  fornecedor     String?
  valor          Decimal      @db.Decimal(12, 2)
  vencimento     DateTime
  recorrente     Boolean      @default(false)
  frequencia     String?      // 'mensal' | 'quinzenal' | 'semanal' | 'anual'
  status         String       @default("pendente") // 'pendente' | 'pago' | 'atrasado'
  pagoEm         DateTime?
  categoria      String?
  observacoes    String?
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt
}

model AlertaEmpresa {
  id             String       @id @default(uuid())
  contaEmpresaId String
  contaEmpresa   ContaEmpresa @relation(fields: [contaEmpresaId], references: [id])
  tipo           String       // 'vencimento' | 'lucro_abaixo_meta' | 'cobranca' | 'resumo_semanal'
  titulo         String
  mensagem       String
  canal          String       @default("whatsapp")
  enviado        Boolean      @default(false)
  enviadoEm      DateTime?
  erro           String?
  criadoEm       DateTime     @default(now())
}

model ConversaIAEmpresa {
  id             String       @id @default(uuid())
  contaEmpresaId String
  contaEmpresa   ContaEmpresa @relation(fields: [contaEmpresaId], references: [id])
  pergunta       String
  resposta       String
  contextoMes    Int?
  contextoAno    Int?
  criadoEm       DateTime     @default(now())
}

// ─── COBRANÇA (Asaas + Z-API) ─────────────────────────────────────────────────

model ClienteDevedor {
  id             String       @id @default(uuid())
  contaEmpresaId String
  contaEmpresa   ContaEmpresa @relation(fields: [contaEmpresaId], references: [id])

  nome            String
  cpfCnpj         String?
  email           String?
  telefone        String?      // WhatsApp para cobrança
  asaasCustomerId String?      // ID do cliente no Asaas

  // Perfil do devedor
  perfilDevedor String @default("primeiro_atraso") // 'primeiro_atraso' | 'segundo_atraso' | 'recorrente' | 'longo_prazo'
  totalDevido   Decimal  @db.Decimal(12, 2) @default(0)
  totalPago     Decimal  @db.Decimal(12, 2) @default(0)

  ativo    Boolean  @default(true)
  cobrancaPausadaAte DateTime? // se preenchido, cobrança automática fica suspensa até esta data
  criadoEm DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  cobrancas CobrancaDevedor[]
  mensagens MensagemCobranca[]
  acordos   AcordoCobranca[]
}

model CobrancaDevedor {
  id              String         @id @default(uuid())
  clienteDevedorId String
  clienteDevedor  ClienteDevedor @relation(fields: [clienteDevedorId], references: [id])

  descricao       String
  valor           Decimal   @db.Decimal(12, 2)
  vencimento      DateTime
  status          String    @default("pendente") // 'pendente' | 'pago' | 'acordo' | 'cancelado'
  asaasPaymentId  String?   @unique // ID do pagamento no Asaas
  asaasLink       String?   // link de pagamento gerado pelo Asaas
  agenteAtivo     Boolean   @default(false)
  etapaAtual      String?   // etapa atual da régua de cobrança

  pagoEm      DateTime?
  valorPago   Decimal?  @db.Decimal(12, 2)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  mensagens MensagemCobranca[]
  acordos   AcordoCobranca[]
}

model MensagemCobranca {
  id               String          @id @default(uuid())
  clienteDevedorId String
  clienteDevedor   ClienteDevedor  @relation(fields: [clienteDevedorId], references: [id])
  cobrancaId       String?
  cobranca         CobrancaDevedor? @relation(fields: [cobrancaId], references: [id])

  direcao  String // 'enviada' | 'recebida'
  canal    String @default("whatsapp") // 'whatsapp' | 'email'
  conteudo String
  enviado  Boolean   @default(false)
  erro     String?
  criadoEm DateTime  @default(now())
}

model AcordoCobranca {
  id               String          @id @default(uuid())
  clienteDevedorId String
  clienteDevedor   ClienteDevedor  @relation(fields: [clienteDevedorId], references: [id])
  cobrancaId       String
  cobranca         CobrancaDevedor @relation(fields: [cobrancaId], references: [id])

  tipo           String  // 'desconto' | 'parcelamento' | 'desconto_parcelamento'
  valorOriginal  Decimal @db.Decimal(12, 2)
  valorAcordado  Decimal @db.Decimal(12, 2)
  parcelas       Int     @default(1)
  status         String  @default("proposto") // 'proposto' | 'aguardando_aprovacao' | 'aceito' | 'recusado' | 'cumprido'

  // Aprovação pelo dono da empresa
  precisaAprovacao Boolean   @default(false)  // true quando desconto > limite automático
  mensagemProposta String?   // mensagem que a IA enviará ao devedor após aprovação
  aprovadoPor      String?   // 'usuario' | 'automatico'
  aprovadoEm       DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// ─── CONCILIAÇÃO DIÁRIA ───────────────────────────────────────────────────────

model ConciliacaoDiaria {
  id             String       @id @default(uuid())
  contaEmpresaId String
  contaEmpresa   ContaEmpresa @relation(fields: [contaEmpresaId], references: [id])

  data             DateTime
  fonte            String   // 'asaas' | 'sicredi' | 'especie'
  status           String   // 'ok' | 'pendencias'
  totalLancamentos Int      @default(0)
  totalConciliados Int      @default(0)
  pendencias       Int      @default(0)
  detalhesJson     String?  @db.Text // JSON com detalhes das pendências

  criadoEm DateTime @default(now())
}

// ─── MODO PESSOAL ─────────────────────────────────────────────────────────────

model ContaPessoal {
  id        String  @id @default(uuid())
  usuarioId String  @unique
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  metaEconomiasMensal Decimal? @db.Decimal(12, 2)
  diaFechamento       Int      @default(1) // dia do mês que fecha o período
  saldoConta          Decimal? @db.Decimal(14, 2) // saldo real da conta bancária (atualizado manualmente)
  saldoContaEm        DateTime? // data/hora da última atualização do saldo

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  categorias    CategoriaPessoal[]
  transacoes    TransacaoPessoal[]
  importacoes   ImportacaoPessoal[]
  investimentos InvestimentoPessoal[]
  orcamentos   OrcamentoPessoal[]
  metas        MetaPessoal[]
  projetos     ProjetoPessoal[]
  conversasIA  ConversaIAPessoal[]
  alertas      AlertaPessoal[]
  contasPagar  ContaPagarPessoal[]
}

model ImportacaoPessoal {
  id             String       @id @default(uuid())
  contaPessoalId String
  contaPessoal   ContaPessoal @relation(fields: [contaPessoalId], references: [id])
  tipo           String       // 'pdf' | 'excel'
  nomeArquivo    String
  banco          String?
  periodo        String?
  criadoEm      DateTime     @default(now())

  transacoes TransacaoPessoal[]
}

model CategoriaPessoal {
  id             String       @id @default(uuid())
  contaPessoalId String
  contaPessoal   ContaPessoal @relation(fields: [contaPessoalId], references: [id])

  nome   String
  tipo   String  // 'receita' | 'despesa'
  cor    String? // hex, para gráficos
  icone  String?
  padrao Boolean @default(false) // categoria padrão do sistema

  criadoEm DateTime @default(now())

  transacoes TransacaoPessoal[]
  orcamentos OrcamentoPessoal[]

  @@unique([contaPessoalId, nome])
}

model TransacaoPessoal {
  id             String       @id @default(uuid())
  contaPessoalId String
  contaPessoal   ContaPessoal @relation(fields: [contaPessoalId], references: [id])
  categoriaId    String?
  categoria      CategoriaPessoal? @relation(fields: [categoriaId], references: [id])
  projetoId      String?
  projeto        ProjetoPessoal?   @relation(fields: [projetoId], references: [id])
  importacaoId   String?
  importacao     ImportacaoPessoal? @relation(fields: [importacaoId], references: [id])

  tipo      String  // 'receita' | 'despesa'
  descricao String
  valor     Decimal @db.Decimal(12, 2)
  data      DateTime
  mes       Int
  ano       Int

  cartao      String?  // nome do cartão (para fatura)
  recorrente  Boolean  @default(false)
  parcelado   Boolean  @default(false)
  totalParcelas Int?
  parcelaAtual  Int?
  origem      String   @default("manual") // 'manual' | 'importacao_excel' | 'importacao_pdf'

  titular   String?  @default("nubia") // 'nubia' | 'matheus' — quem fez o gasto
  entidade  String   @default("pessoal") // 'pessoal' | 'lar' | 'pj'

  observacoes String?
  criadoEm    DateTime @default(now())
}

model OrcamentoPessoal {
  id             String           @id @default(uuid())
  contaPessoalId String
  contaPessoal   ContaPessoal     @relation(fields: [contaPessoalId], references: [id])
  categoriaId    String
  categoria      CategoriaPessoal @relation(fields: [categoriaId], references: [id])

  mes        Int
  ano        Int
  valorMeta  Decimal @db.Decimal(12, 2)
  valorGasto Decimal @db.Decimal(12, 2) @default(0)
  titular    String? // 'nubia' | 'matheus' | null = compartilhado

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([contaPessoalId, categoriaId, mes, ano])
}

model MetaPessoal {
  id             String       @id @default(uuid())
  contaPessoalId String
  contaPessoal   ContaPessoal @relation(fields: [contaPessoalId], references: [id])

  titulo       String
  descricao    String?
  valorMeta    Decimal  @db.Decimal(12, 2)
  valorAtual   Decimal  @db.Decimal(12, 2) @default(0)
  prazo        DateTime?
  status       String   @default("ativa") // 'ativa' | 'concluida' | 'pausada'

  estrategiaIA    String?  // JSON com a estratégia gerada pela IA (salva uma vez)
  estrategiaGerada Boolean @default(false)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model InvestimentoPessoal {
  id                    String       @id @default(uuid())
  contaPessoalId        String
  contaPessoal          ContaPessoal @relation(fields: [contaPessoalId], references: [id])

  produto               String       // ex: SICREDINVEST CDI100
  titulo                String?      // código do título
  indexador             String?      // CDI, IPCA, etc.
  remuneracao           String?      // 100% CDI
  valorInicial          Decimal      @db.Decimal(12, 2)
  dataAplicacao         DateTime
  vencimento            DateTime?
  carencia              DateTime?
  tributacao            String?

  saldoAtual            Decimal      @db.Decimal(12, 2)
  rendimentosProvisionados Decimal   @db.Decimal(12, 2) @default(0)
  liquidoSaque          Decimal      @db.Decimal(12, 2)

  atualizadoEm          DateTime     @default(now())
  criadoEm              DateTime     @default(now())

  @@unique([contaPessoalId, titulo])
}

model ProjetoPessoal {
  id             String       @id @default(uuid())
  contaPessoalId String
  contaPessoal   ContaPessoal @relation(fields: [contaPessoalId], references: [id])

  nome      String
  descricao String?
  orcamento Decimal?  @db.Decimal(12, 2)
  status    String    @default("ativo") // 'ativo' | 'concluido' | 'pausado'
  cor       String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  transacoes TransacaoPessoal[]
}

model ContaPagarPessoal {
  id             String       @id @default(uuid())
  contaPessoalId String
  contaPessoal   ContaPessoal @relation(fields: [contaPessoalId], references: [id])

  descricao   String
  fornecedor  String?
  categoria   String?       // ex: "Casamento", "Moradia"
  tag         String?       // ex: "casamento" — para agrupar por evento
  valor       Decimal       @db.Decimal(12, 2)
  vencimento  DateTime?
  status      String        @default("pendente") // 'pendente' | 'pago' | 'atrasado'
  pagoEm      DateTime?
  observacoes String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("conta_pagar_pessoal")
}

model ConversaIAPessoal {
  id             String       @id @default(uuid())
  contaPessoalId String
  contaPessoal   ContaPessoal @relation(fields: [contaPessoalId], references: [id])

  pergunta    String
  resposta    String
  contextoMes Int?
  contextoAno Int?
  criadoEm    DateTime @default(now())
}

model AlertaPessoal {
  id             String       @id @default(uuid())
  contaPessoalId String
  contaPessoal   ContaPessoal @relation(fields: [contaPessoalId], references: [id])

  tipo      String    // 'orcamento_estourado' | 'meta_progresso' | 'resumo_mensal'
  titulo    String
  mensagem  String
  canal     String    @default("whatsapp")
  enviado   Boolean   @default(false)
  enviadoEm DateTime?
  erro      String?
  criadoEm  DateTime  @default(now())
}

// ─── ASSINATURAS / MONETIZAÇÃO ────────────────────────────────────────────────

model AssinaturaRadar {
  id              String   @id @default(uuid())
  usuarioId       String   @unique
  usuario         Usuario  @relation(fields: [usuarioId], references: [id])
  plano           String   // 'pro' | 'premium'
  status          String   @default("pendente") // pendente | ativa | cancelada | inadimplente
  asaasSubId      String?  @unique // ID da assinatura no Asaas
  valorMensal     Decimal  @db.Decimal(10, 2)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
  venceEm         DateTime?
  linkPagamento   String?
  pagamentos      PagamentoAssinatura[]
  @@map("assinatura_radar")
}

model PagamentoAssinatura {
  id             String          @id @default(uuid())
  assinaturaId   String
  assinatura     AssinaturaRadar @relation(fields: [assinaturaId], references: [id])
  asaasPaymentId String?         @unique
  valor          Decimal         @db.Decimal(10, 2)
  status         String          @default("PENDING")
  vencimento     DateTime
  pagoEm         DateTime?
  linkPagamento  String?
  criadoEm       DateTime        @default(now())
  @@map("pagamento_assinatura")
}

model CupomDesconto {
  id          String    @id @default(uuid())
  codigo      String    @unique
  descricao   String?
  tipo        String    // 'trial' | 'percentual' | 'fixo'
  valor       Decimal   @db.Decimal(10, 2) @default(0) // % ou R$ de desconto; 0 = trial grátis
  diasTrial   Int?      // dias grátis (para tipo='trial')
  planoAlvo   String    // 'pro' | 'premium' | 'ambos'
  ativo       Boolean   @default(true)
  usoMax      Int?      // null = ilimitado
  usoAtual    Int       @default(0)
  validoAte   DateTime?
  criadoEm    DateTime  @default(now())
  usos        UsoCupom[]
  @@map("cupom_desconto")
}

model UsoCupom {
  id        String        @id @default(uuid())
  cupomId   String
  cupom     CupomDesconto @relation(fields: [cupomId], references: [id])
  usuarioId String
  usadoEm   DateTime      @default(now())
  @@unique([cupomId, usuarioId])
  @@map("uso_cupom")
}
